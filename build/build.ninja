build esp-idf/esp_rom/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cmd.exe /C "cd /D C:\esp\esp-zigbee-sdk\examples\sleepy_devices\light_sleep_end_device\build\esp-idf\esp_rom && C:\Espressif\tools\cmake\3.24.0\bin\cmake-gui.exe -SC:\esp\esp-zigbee-sdk\examples\sleepy_devices\light_sleep_end_device -BC:\esp\esp-zigbee-sdk\examples\sleepy_devices\light_sleep_end_device\build"
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

